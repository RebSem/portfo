# Runtime environment for docker-compose (do not commit real values).
# GitHub token for API requests (recommended for stable rate limits).
GITHUB_TOKEN=REPLACE_WITH_YOUR_TOKEN

# Path to persistent cache file inside container.
GITHUB_CACHE_FILE=/app/data/github-cache.json

# Analytics project token. Public and write-only: it is inlined into the built
# JS and readable by anyone who views the deployed site, so this is about
# hygiene and rotation, not secrecy. In CI it comes from the repository secret
# of the same name. Leave unset to build with analytics compiled out.
PUBLIC_ANALYTICS_KEY=

# Ingestion host. Only change this if a proxy is ever put in front.
PUBLIC_ANALYTICS_HOST=https://eu.i.posthog.com
