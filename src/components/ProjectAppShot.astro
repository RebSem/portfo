---
// App-window screenshot for self-contained desktop apps that already carry
// their own window chrome. Unlike ProjectScreenshot, it does NOT draw a
// traffic-light bar (the app already has a header), so we avoid a
// window-in-a-window look. Light/dark variants swap via theme-images.js,
// so only the active theme's image is ever fetched.
//
// Use one shot, or pass `shots` (2 items) for a responsive side-by-side duo.
interface Shot {
  lightSrc: string;
  darkSrc: string;
  alt: string;
  caption?: string;
}

interface Props {
  lightSrc?: string;
  darkSrc?: string;
  alt?: string;
  caption?: string;
  shots?: Shot[];
  width?: number;
  height?: number;
}

const { lightSrc, darkSrc, alt, caption, shots, width = 1240, height = 1956 } = Astro.props;

const panes: Shot[] = shots ?? [
  { lightSrc: lightSrc!, darkSrc: darkSrc!, alt: alt!, caption },
];
const isDuo = panes.length > 1;
---

<figure class:list={["app-shot", { "app-shot-duo": isDuo }]}>
  {panes.map((p) => (
    <figure class="app-shot-pane">
      <div class="app-shot-frame">
        <img
          src={p.lightSrc}
          data-light-src={p.lightSrc}
          data-dark-src={p.darkSrc}
          alt={p.alt}
          class="app-shot-img"
          loading="lazy"
          decoding="async"
          width={width}
          height={height}
        />
      </div>
      {p.caption && <figcaption class="app-shot-caption">{p.caption}</figcaption>}
    </figure>
  ))}
</figure>
