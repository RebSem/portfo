---
import { execSync } from 'node:child_process';
import { agentOps, githubUsername } from '../data/site-content';
import type { Locale } from '../types/content';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const c = agentOps;

// Baked at build time; CI builds run from a real checkout, so this resolves
// to the deployed commit. Hidden entirely when git is unavailable.
let commitHash = '';
try {
  commitHash = execSync('git rev-parse --short HEAD', { encoding: 'utf8' }).trim();
} catch {
  // No git in the build environment — drop the deploy line.
}

const repoSlug = `${githubUsername}/portfo`;
const mergedPrsUrl = `https://github.com/${repoSlug}/pulls?q=is%3Apr+is%3Amerged`;
---

<section class="section-block agent-ops" aria-labelledby="agent-ops-title" data-agent-repo={repoSlug}>
  <div class="section-head">
    <p class="about-eyebrow">{c.eyebrow[locale]}</p>
    <h2 id="agent-ops-title">{c.title[locale]}</h2>
    <p class="agent-ops-lead">{c.lead[locale]}</p>
  </div>

  <div class="agent-ops-grid">
    <ol class="agent-steps">
      {c.steps.map((step) => (
        <li class="agent-step">
          <span class="agent-step-num" aria-hidden="true">{step.k}</span>
          <div class="agent-step-copy">
            <h3>{step.title[locale]}</h3>
            <p>{step.body[locale]}</p>
          </div>
        </li>
      ))}
    </ol>

    <aside class="agent-terminal" aria-label={c.terminalAria[locale]}>
      <div class="agent-terminal-bar" aria-hidden="true">
        <span class="agent-terminal-dot"></span>
        <span class="agent-terminal-dot"></span>
        <span class="agent-terminal-dot"></span>
        <span class="agent-terminal-title">agent ops: {repoSlug}</span>
      </div>
      <div class="agent-terminal-body">
        <p class="t-cmd">gh pr list --state merged</p>
        <p class="t-out">
          <strong class="t-num" data-agent-pr-count>31</strong>
          <span>{c.receiptPrs[locale]}</span>
        </p>
        <p class="t-link">
          <a href={mergedPrsUrl} target="_blank" rel="noreferrer">{c.receiptPrsLink[locale]} ↗</a>
        </p>

        {commitHash && (
          <>
            <p class="t-cmd">git rev-parse --short HEAD</p>
            <p class="t-out">
              <strong class="t-num">{commitHash}</strong>
              <span>{c.receiptDeployNote[locale]}</span>
            </p>
          </>
        )}

        <p class="t-cmd">whoami</p>
        <p class="t-out t-whoami">agent-native product manager<span class="t-caret" aria-hidden="true"></span></p>
      </div>
    </aside>
  </div>
</section>

<script>
  // Live-refresh the merged-PR count from the GitHub search API.
  // The baked number stays as the fallback when the request fails
  // (rate limit, offline) — never show an empty or broken value.
  const refreshPrCount = async () => {
    const section = document.querySelector('[data-agent-repo]');
    if (!section) return;

    const repo = section.getAttribute('data-agent-repo');
    const nodes = document.querySelectorAll('[data-agent-pr-count]');
    if (!repo || nodes.length === 0) return;

    try {
      const response = await fetch(
        `https://api.github.com/search/issues?q=repo:${repo}+is:pr+is:merged&per_page=1`,
        { headers: { Accept: 'application/vnd.github+json' } },
      );
      if (!response.ok) return;

      const payload = await response.json();
      if (typeof payload?.total_count === 'number' && payload.total_count > 0) {
        nodes.forEach((node) => {
          node.textContent = String(payload.total_count);
        });
      }
    } catch {
      // Keep the baked fallback.
    }
  };

  document.addEventListener('astro:page-load', refreshPrCount);

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => void refreshPrCount(), { once: true });
  } else {
    void refreshPrCount();
  }
</script>
