---
import type { Locale } from '../types/content';
import { uiCopy } from '../data/site-content';
import type { ProjectItem } from '../types/content';

interface Props {
  project: ProjectItem;
  locale: Locale;
  screenshotLight: string;
  screenshotDark: string;
  caseHref?: string;
}

const { project, locale, screenshotLight, screenshotDark, caseHref } = Astro.props;
const c = uiCopy.projects;
const readCaseLabel = locale === 'ru' ? 'Открыть полный кейс' : 'Read the full case';
---

<article class="featured-case" aria-labelledby={`featured-${project.id}-title`}>
  <div class="featured-case-copy">
    <header class="featured-case-head">
      <span class="featured-case-eyebrow">{c.featuredEyebrow[locale]}</span>
      <span class="featured-case-live">
        <span class="pulse-dot"></span>
        {c.featuredLiveBadge[locale]}
      </span>
    </header>

    <h3 id={`featured-${project.id}-title`} class="featured-case-title">
      {caseHref ? <a href={caseHref}>{project.title[locale]}</a> : project.title[locale]}
    </h3>
    <p class="featured-case-type">{project.appType[locale]}</p>

    <p class="featured-case-role">{c.featuredRole[locale]}</p>

    <ul class="featured-case-kpis" aria-label="Project highlights">
      {c.featuredKpis.map((kpi) => (
        <li class="featured-case-kpi">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M20 6 9 17l-5-5"/>
          </svg>
          <span>{kpi[locale]}</span>
        </li>
      ))}
    </ul>

    <p class="featured-case-summary">{project.summary[locale]}</p>

    <div class="featured-case-highlights">
      <p class="featured-case-highlights-title">{c.featuredHighlightsTitle[locale]}</p>
      <ul>
        {c.featuredHighlights.map((h) => (
          <li>{h[locale]}</li>
        ))}
      </ul>
    </div>

    <ul class="featured-case-stack" aria-label={c.stackAria[locale]}>
      {project.stack.map((item) => (<li>{item}</li>))}
    </ul>

    {caseHref && (
      <a class="featured-case-cta" href={caseHref}>
        {readCaseLabel}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
      </a>
    )}
  </div>

  <aside class="featured-case-visual" aria-hidden="false">
    <figure class="featured-case-frame">
      <div class="featured-case-frame-bar" aria-hidden="true">
        <span class="featured-case-frame-dot"></span>
        <span class="featured-case-frame-dot"></span>
        <span class="featured-case-frame-dot"></span>
        <span class="featured-case-frame-url">zvonobot-ai · client console</span>
      </div>
      <img
        src={screenshotLight}
        alt={c.featuredScreenshotAlt[locale]}
        loading="lazy"
        decoding="async"
        width="1440"
        height="920"
        class="featured-case-shot featured-case-shot-light"
      />
      <img
        src={screenshotDark}
        alt={c.featuredScreenshotAlt[locale]}
        loading="lazy"
        decoding="async"
        width="1440"
        height="920"
        class="featured-case-shot featured-case-shot-dark"
      />
    </figure>
    <figcaption class="featured-case-caption">{c.featuredNda[locale]}</figcaption>
  </aside>
</article>
