---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  noIndex?: boolean;
  schema?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title = 'Mikhail Semenov - Portfolio',
  description = 'Interactive portfolio with GitHub activity, projects, and blog posts.',
  image = '/main-hero.jpg',
  type = 'website',
  noIndex = false,
  schema = [],
} = Astro.props;

const lang = Astro.currentLocale ?? 'en';
const siteUrl = Astro.site ?? new URL(Astro.url.origin);
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const imageUrl = image.startsWith('http://') || image.startsWith('https://') ? image : new URL(image, siteUrl).toString();
const robotsContent = noIndex ? 'noindex,nofollow' : 'index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1';
const resolvedSchemas = Array.isArray(schema) ? schema : [schema];
---

<!doctype html>
<html lang={lang} data-locale={lang}>
  <head>
    <script is:inline>
      (() => {
        const root = document.documentElement;

        const detectTheme = () => {
          try {
            const storedTheme = window.localStorage.getItem('portfolio-theme');
            if (storedTheme === 'dark' || storedTheme === 'light') return storedTheme;
          } catch {
            // Ignore storage access failures.
          }

          return typeof window.matchMedia === 'function' && window.matchMedia('(prefers-color-scheme: dark)').matches
            ? 'dark'
            : 'light';
        };

        const theme = detectTheme();
        root.setAttribute('data-theme', theme);
        root.style.colorScheme = theme;
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content={robotsContent} />
    <meta name="author" content="Mikhail Semenov" />
    <meta name="theme-color" content="#f4f6fb" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:site_name" content="Mikhail Semenov" />
    <meta property="og:type" content={type} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:locale:alternate" content="ru_RU" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:alt" content={title} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content={title} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="shortcut icon" href="/favicon.ico" />
    {resolvedSchemas.map((entry) => <script is:inline type="application/ld+json" set:html={JSON.stringify(entry)}></script>)}
  </head>
  <body>
    <ClientRouter fallback="swap" />
    <slot />
  </body>
</html>
