---
import { Font } from 'astro:assets';
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import Analytics from '../components/Analytics.astro';
import themeImagesScriptUrl from '../scripts/theme-images.js?url';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  noIndex?: boolean;
  schema?: Record<string, unknown> | Array<Record<string, unknown>>;
  /** Path of this page in the other locale, e.g. '/ru/about' — emits hreflang alternates. */
  alternate?: string;
}

const {
  title = 'Mikhail Semenov - Portfolio',
  description = 'Interactive portfolio with GitHub activity, projects, and blog posts.',
  image = '/main-hero.jpg',
  type = 'website',
  noIndex = false,
  schema = [],
  alternate,
} = Astro.props;

const lang = Astro.currentLocale ?? 'en';
const siteUrl = Astro.site ?? new URL(Astro.url.origin);
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const imageUrl = image.startsWith('http://') || image.startsWith('https://') ? image : new URL(image, siteUrl).toString();
// The default hero is a known 1200x900; only emit og:image dimensions for it.
const isDefaultImage = image === '/main-hero.jpg';
const robotsContent = noIndex ? 'noindex,nofollow' : 'index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1';
const resolvedSchemas = Array.isArray(schema) ? schema : [schema];
const ogLocale = lang === 'ru' ? 'ru_RU' : 'en_US';
const ogLocaleAlternate = lang === 'ru' ? 'en_US' : 'ru_RU';
const alternateUrl = alternate ? new URL(alternate, siteUrl).toString() : undefined;
const hreflangEn = lang === 'ru' ? alternateUrl : canonicalUrl;
const hreflangRu = lang === 'ru' ? canonicalUrl : alternateUrl;
---

<!doctype html>
<html lang={lang} data-locale={lang}>
  <head>
    <script is:inline>
      (() => {
        const root = document.documentElement;

        const detectTheme = () => {
          try {
            const storedTheme = window.localStorage.getItem('portfolio-theme');
            if (storedTheme === 'dark' || storedTheme === 'light') return storedTheme;
          } catch {
            // Ignore storage access failures.
          }

          return typeof window.matchMedia === 'function' && window.matchMedia('(prefers-color-scheme: dark)').matches
            ? 'dark'
            : 'light';
        };

        const theme = detectTheme();
        root.setAttribute('data-theme', theme);
        root.style.colorScheme = theme;
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <Font cssVariable="--font-geist" preload />
    <Font cssVariable="--font-newsreader" preload />
    <Font cssVariable="--font-geist-mono" />
    <link rel="dns-prefetch" href="https://api.github.com" />
    <meta name="description" content={description} />
    <meta name="robots" content={robotsContent} />
    <meta name="author" content="Mikhail Semenov" />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#f4f4f1" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#0c0d0e" />
    <link rel="canonical" href={canonicalUrl} />
    {alternateUrl && hreflangEn && <link rel="alternate" hreflang="en" href={hreflangEn} />}
    {alternateUrl && hreflangRu && <link rel="alternate" hreflang="ru" href={hreflangRu} />}
    {alternateUrl && hreflangEn && <link rel="alternate" hreflang="x-default" href={hreflangEn} />}
    <meta property="og:site_name" content="Mikhail Semenov" />
    <meta property="og:type" content={type} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlternate} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    {isDefaultImage && <meta property="og:image:width" content="1200" />}
    {isDefaultImage && <meta property="og:image:height" content="900" />}
    <meta property="og:image:alt" content={title} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content={title} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="manifest" href="/manifest.webmanifest" />
    {resolvedSchemas.map((entry) => <script is:inline type="application/ld+json" set:html={JSON.stringify(entry)}></script>)}
    <Analytics />
  </head>
  <body id="top">
    <ClientRouter fallback="swap" />
    <slot />
    <script is:inline type="module" src={themeImagesScriptUrl}></script>
  </body>
</html>
