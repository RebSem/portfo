---
import { getCollection, render } from 'astro:content';
import SiteFooter from '../../../components/SiteFooter.astro';
import SiteHeader from '../../../components/SiteHeader.astro';
import { githubUsername, heroDisplayName, linkedinUrl, telegramUrl } from '../../../data/site-content';
import Layout from '../../../layouts/Layout.astro';
import localeScriptUrl from '../../../scripts/locale.js?url';

export async function getStaticPaths() {
  const projectEntries = await getCollection('projects', ({ data }) => !data.draft && data.lang === 'ru');
  return projectEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

// Find English version for switcher
const allProjects = await getCollection('projects', ({ data }) => !data.draft);
const enSlug = allProjects.find((p) => p.data.projectId === entry.data.projectId && p.data.lang === 'en')?.slug;

const pageImage = entry.data.cover ?? '/main-hero.jpg';
const projectSchema = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: entry.data.title,
  description: entry.data.description,
  inLanguage: 'ru',
  image: pageImage.startsWith('http://') || pageImage.startsWith('https://')
    ? pageImage
    : `https://rebsem.ru${pageImage}`,
  url: `https://rebsem.ru/ru/projects/${entry.slug}`,
  author: {
    '@type': 'Person',
    name: heroDisplayName.en,
    alternateName: heroDisplayName.ru,
    sameAs: [
      `https://github.com/${githubUsername}`,
      telegramUrl,
      linkedinUrl,
    ],
  },
};
---

<Layout
  title={`${entry.data.title} - ${heroDisplayName.ru}`}
  description={entry.data.description}
  image={pageImage}
  schema={projectSchema}
>
  <a id="skip-to-content" href="#main-content" class="skip-link">Перейти к содержимому</a>

  <SiteHeader active="home" />

  <div class="divider-wrap" aria-hidden="true">
    <hr class="divider" />
  </div>

  <main
    id="main-content"
    class="page-main"
    data-post-slug-en={enSlug ?? ''}
  >
    <article class="post-shell">
      <p>
        <a href="/ru">← На главную</a>
      </p>

      <header class="post-head">
        <h1>{entry.data.title}</h1>
        <p class="post-lead">{entry.data.description}</p>
      </header>

      {(entry.data.role || entry.data.timeline || entry.data.impact) && (
        <div class="project-quick-facts">
          {entry.data.role && (
            <div class="fact-item">
              <span class="fact-label">Роль</span>
              <span class="fact-value">{entry.data.role}</span>
            </div>
          )}
          {entry.data.timeline && (
            <div class="fact-item">
              <span class="fact-label">Сроки</span>
              <span class="fact-value">{entry.data.timeline}</span>
            </div>
          )}
          {entry.data.impact && (
            <div class="fact-item impact-fact">
              <span class="fact-label">Результат</span>
              <span class="fact-value">{entry.data.impact}</span>
            </div>
          )}
        </div>
      )}

      {entry.data.tags.length > 0 && (
        <ul class="stack-list" aria-label="Технологии проекта">
          {entry.data.tags.map((tag) => (
            <li>{tag}</li>
          ))}
        </ul>
      )}

      <div class="prose">
        <Content />
      </div>
    </article>
  </main>

  <SiteFooter />

  <script is:inline type="module" src={localeScriptUrl}></script>
</Layout>
