---
import { getCollection } from 'astro:content';
import FeaturedCase from '../../components/FeaturedCase.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SocialLinks from '../../components/SocialLinks.astro';
import { projects } from '../../data/projects';
import {
  githubUsername,
  heroDisplayName,
  linkedinUrl,
  telegramUrl,
  uiCopy,
} from '../../data/site-content';
import Layout from '../../layouts/Layout.astro';
import githubScriptUrl from '../../scripts/github-activity.js?url';
import githubSyncScriptUrl from '../../scripts/github-sync.js?url';
import localeScriptUrl from '../../scripts/locale.js?url';

const visibleProjects = projects.filter((project) => !project.placeholder);
const featuredCaseProject = visibleProjects.find((p) => p.id === 'zvonobot-ai');
const workLedProjects = visibleProjects.filter((p) => p.tier === 'work-led' && p.id !== 'zvonobot-ai');
const petProjects = visibleProjects.filter((p) => p.tier === 'pet');
const projectEntries = await getCollection('projects', ({ data }) => !data.draft && data.lang === 'ru');

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: heroDisplayName.en,
  alternateName: heroDisplayName.ru,
  jobTitle: 'Product Manager (AI) / Product Engineer',
  url: 'https://rebsem.ru/ru',
  image: 'https://rebsem.ru/main-hero.jpg',
  sameAs: [
    `https://github.com/${githubUsername}`,
    telegramUrl,
    linkedinUrl,
  ],
};
---

<Layout
  title={`${heroDisplayName.ru} - Voice AI Product Manager`}
  description="Voice AI Product Manager в Prof-IT (zvonobot, effebot, p1sms). 500 000+ минут B2B-разговоров через AI-агентов за 2026. Пет-проекты собираю за дни, чтобы быстрее валидировать гипотезы."
  schema={personSchema}
>
  <a id="skip-to-content" href="#main-content" class="skip-link">Перейти к содержимому</a>

  <SiteHeader active="home" />

  <main id="main-content" class="page-main" data-github-username={githubUsername}>
    <section class="home-intro" aria-labelledby="home-title">
      <div class="home-intro-copy">
        <span class="hero-status">
          <span class="pulse-dot"></span>
          {uiCopy.home.heroStatus.ru}
        </span>

        <p class="about-eyebrow">{uiCopy.home.eyebrow.ru}</p>

        <h1 id="home-title">
          Product Manager. <span class="hero-accent">Voice&nbsp;AI.</span>
        </h1>

        <p class="home-lead">
          {uiCopy.home.lead.ru}
          <br />
          <span class="home-lead-strong">{uiCopy.home.leadStrong.ru}</span>
        </p>

        <div class="hero-cta-row">
          <a class="cta-button cta-primary" href={telegramUrl} target="_blank" rel="noreferrer">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4 11l16 -8l-4 18l-5 -4l-3 3l1 -5l8 -7"/>
            </svg>
            {uiCopy.home.heroCtaPrimary.ru}
          </a>
        </div>

        <SocialLinks className="social-links profile-social-links" />
      </div>

      <aside class="hero-metric-card" aria-label="Ключевая метрика">
        <p class="hero-metric-label">{uiCopy.home.metricLabel.ru}</p>
        <p class="hero-metric-value">
          {uiCopy.home.metricNumber}<span class="unit">{uiCopy.home.metricUnit.ru}</span>
        </p>
        <p class="hero-metric-caption">{uiCopy.home.metricCaption.ru}</p>
        <p class="hero-metric-footnote">
          <span>{uiCopy.home.metricFootnoteOne.ru}</span>
          <span>{uiCopy.home.metricFootnoteTwo.ru}</span>
        </p>
      </aside>
    </section>

    <section class="section-block currently-section" aria-labelledby="currently-title">
      <div class="section-head">
        <p class="about-eyebrow">{uiCopy.home.currentlyEyebrow.ru}</p>
        <h2 id="currently-title">{uiCopy.home.currentlyTitle.ru}</h2>
      </div>

      <dl class="currently-grid">
        <div class="currently-item">
          <dt>{uiCopy.home.currentlyRoleLabel.ru}</dt>
          <dd>{uiCopy.home.currentlyRole.ru}</dd>
        </div>
        <div class="currently-item">
          <dt>{uiCopy.home.currentlyFocusLabel.ru}</dt>
          <dd>{uiCopy.home.currentlyFocus.ru}</dd>
        </div>
        <div class="currently-item currently-item-metric">
          <dt>{uiCopy.home.currentlyMetricLabel.ru}</dt>
          <dd>{uiCopy.home.currentlyMetricValue.ru}</dd>
        </div>
      </dl>

      <div class="github-inline" aria-labelledby="github-title">
        <div class="github-inline-meta">
          <span class="label">GitHub · за год</span>
          <strong id="contributions-total">0</strong>
          <span class="label" id="github-title">вкладов</span>
          <a
            class="github-profile-link link"
            href={`https://github.com/${githubUsername}`}
            target="_blank"
            rel="noreferrer"
          >
            github.com/{githubUsername}
          </a>
        </div>

        <div class="github-heatmap">
          <div
            id="contribution-grid"
            class="contribution-grid"
            role="img"
            aria-label="График активности GitHub"
          ></div>

          <div class="heatmap-legend" aria-hidden="true">
            <span>0</span>
            <div class="legend-level level-0"></div>
            <div class="legend-level level-1"></div>
            <div class="legend-level level-2"></div>
            <div class="legend-level level-3"></div>
            <div class="legend-level level-4"></div>
            <span>max</span>
          </div>

          <p
            id="contribution-tooltip"
            class="contribution-tooltip"
            data-hint-ru="Наведите или перейдите на ячейку, чтобы увидеть дату и число вкладов."
            data-hint-en="Hover or focus a cell to see the exact date and number of contributions."
          >
            Наведите или перейдите на ячейку, чтобы увидеть дату и число вкладов.
          </p>

          <p
            id="github-error"
            class="github-error hidden"
          >
            Не удалось загрузить GitHub-данные. Попробуйте обновить страницу позже.
          </p>
        </div>
      </div>
    </section>

    <section id="projects" class="section-block" aria-labelledby="projects-title">
      <div class="section-head">
        <p class="about-eyebrow">{uiCopy.projects.title.ru}</p>
        <h2 id="projects-title">Выбранные работы</h2>
        <p>{uiCopy.projects.subtitle.ru}</p>
      </div>

      <div class="projects-tier">
        <div class="projects-tier-head">
          <span class="tier-eyebrow">{uiCopy.projects.workLedEyebrow.ru}</span>
          <h3>{uiCopy.projects.workLedTitle.ru}</h3>
          <p>{uiCopy.projects.workLedNote.ru}</p>
        </div>

        {featuredCaseProject && (() => {
          const fEntry = projectEntries.find((e) => e.data.projectId === featuredCaseProject.id);
          return (
            <FeaturedCase
              project={featuredCaseProject}
              locale="ru"
              screenshotLight="/projects/zvonobot-dashboard-ru-light.png"
              screenshotDark="/projects/zvonobot-dashboard-ru-dark.png"
              caseHref={fEntry ? `/ru/projects/${fEntry.slug}/` : undefined}
            />
          );
        })()}

        <div class="projects-led-grid">
          {workLedProjects.map((project) => {
            const entry = projectEntries.find(e => e.data.projectId === project.id);
            return (
              <article
                class:list={["project-card", project.id === 'cursivo' && "project-card-featured"]}
                data-github-repo={project.githubRepo}
              >
                <div class="project-card-head">
                  {entry ? (
                    <h3><a href={`/ru/projects/${entry.slug}/`}>{project.title.ru}</a></h3>
                  ) : (
                    <h3>{project.title.ru}</h3>
                  )}
                  {project.id === 'cursivo' && (
                    <div class="launch-badge launch-badge-ru">
                      <span class="pulse-dot"></span>
                      В работе
                    </div>
                  )}
                  {project.id === 'obrabot' && (
                    <span class="project-visibility">Внутренний продукт Prof-IT</span>
                  )}
                </div>

                <p>{project.summary.ru}</p>
                <p class="project-meta">
                  <strong>Тип</strong>
                  <span>{project.appType.ru}</span>
                </p>
                {project.githubRepo && (
                  <div class="project-live-facts" aria-label="Актуальные данные репозитория GitHub">
                    <p class="project-fact-chip">
                      <span>Язык</span>
                      <strong data-github-language>{project.stack[0]}</strong>
                    </p>
                    <p class="project-fact-chip">
                      <span>Звезды</span>
                      <strong data-github-stars>0</strong>
                    </p>
                    <p class="project-fact-chip">
                      <span>Последний push</span>
                      <strong data-github-updated>Синхронизация…</strong>
                    </p>
                  </div>
                )}
                <ul class="stack-list" aria-label="Технологии проекта">
                  {project.stack.map((item) => (<li>{item}</li>))}
                </ul>
                <p class="project-links">
                  {entry && (
                    <a
                      class="project-link"
                      href={`/ru/projects/${entry.slug}`}
                      data-details-link
                    >
                      Подробнее
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
                    </a>
                  )}
                  {project.demoUrl && (
                    <a class="project-link" href={project.demoUrl} target="_blank" rel="noreferrer">
                      Демо
                    </a>
                  )}
                  {project.repoUrl && (
                    <a
                      class="project-link"
                      href={project.repoUrl}
                      target="_blank"
                      rel="noreferrer"
                      data-github-repo-link={project.githubRepo ? '' : undefined}
                    >
                      Репозиторий
                    </a>
                  )}
                </p>
              </article>
            );
          })}
        </div>
      </div>

      <div class="projects-tier">
        <div class="projects-tier-head">
          <span class="tier-eyebrow">{uiCopy.projects.petEyebrow.ru}</span>
          <h3>{uiCopy.projects.petTitle.ru}</h3>
          <p>{uiCopy.projects.petNote.ru}</p>
        </div>

        <div class="projects-pet-grid">
          {petProjects.map((project) => {
            const entry = projectEntries.find(e => e.data.projectId === project.id);
            return (
              <article
                class="project-card-pet"
                data-github-repo={project.githubRepo}
              >
                {project.shipTime && (
                  <span class="pet-ship-time">
                    <span class="pulse-dot"></span>
                    {project.shipTime.ru}
                  </span>
                )}
                {entry ? (
                  <h4><a href={`/ru/projects/${entry.slug}/`}>{project.title.ru}</a></h4>
                ) : (
                  <h4>{project.title.ru}</h4>
                )}
                <p class="pet-type">{project.appType.ru}</p>
                <p class="pet-stack">{project.stack.join(' · ')}</p>
                {project.repoUrl && (
                  <a class="pet-repo-link" href={project.repoUrl} target="_blank" rel="noreferrer">
                    github →
                  </a>
                )}
              </article>
            );
          })}
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />

  <script is:inline type="module" src={localeScriptUrl}></script>
  <script is:inline type="module" src={githubScriptUrl}></script>
  <script is:inline type="module" src={githubSyncScriptUrl}></script>
</Layout>
