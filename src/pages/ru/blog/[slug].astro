---
import { getCollection, getEntry, render } from 'astro:content';
import SiteFooter from '../../../components/SiteFooter.astro';
import SiteHeader from '../../../components/SiteHeader.astro';
import { githubUsername, heroDisplayName, linkedinUrl, telegramUrl, uiCopy } from '../../../data/site-content';
import Layout from '../../../layouts/Layout.astro';
import localeScriptUrl from '../../../scripts/locale.js?url';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft && data.lang === 'ru');
  return posts.map((post) => ({
    params: { slug: post.slug },
  }));
}

const slug = Astro.params.slug ?? '';
const post = await getEntry('blog', slug);
if (!post || post.data.draft) {
  return Astro.redirect('/ru/blog', 302);
}

// Find English version for switcher
const translationPairPosts = await getCollection(
  'blog',
  ({ data }) => !data.draft && data.translationKey === post.data.translationKey,
);
const enSlug = translationPairPosts.find((entry) => entry.data.lang === 'en')?.slug;

const { Content } = await render(post);

const isoDate = post.data.publishedAt.toISOString().slice(0, 10);
const dateLabel = new Intl.DateTimeFormat('ru-RU', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
}).format(post.data.publishedAt);

const pageImage = post.data.cover ?? '/main-hero.jpg';
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.publishedAt.toISOString(),
  dateModified: (post.data.updatedAt ?? post.data.publishedAt).toISOString(),
  inLanguage: 'ru',
  image: pageImage.startsWith('http://') || pageImage.startsWith('https://')
    ? pageImage
    : `https://rebsem.ru${pageImage}`,
  url: `https://rebsem.ru/ru/blog/${post.slug}`,
  mainEntityOfPage: `https://rebsem.ru/ru/blog/${post.slug}`,
  author: {
    '@type': 'Person',
    name: heroDisplayName.en,
    alternateName: heroDisplayName.ru,
    sameAs: [
      `https://github.com/${githubUsername}`,
      telegramUrl,
      linkedinUrl,
    ],
  },
};
---

<Layout
  title={`${post.data.title} - ${heroDisplayName.ru}`}
  description={post.data.description}
  image={pageImage}
  type="article"
  schema={articleSchema}
>
  <a id="skip-to-content" href="#main-content" class="skip-link">Перейти к содержимому</a>

  <SiteHeader active="blog" />

  <div class="divider-wrap" aria-hidden="true">
    <hr class="divider" />
  </div>

  <main
    id="main-content"
    class="page-main"
    data-post-slug-en={enSlug ?? ''}
  >
    <article class="post-shell">
      <p>
        <a href="/ru/blog">← Вернуться в блог</a>
      </p>

      <header class="post-head">
        <p class="post-meta">
          <time datetime={isoDate}>{dateLabel}</time>
        </p>
        <h1>{post.data.title}</h1>
        <p>{post.data.description}</p>
      </header>

      {post.data.tags.length > 0 && (
        <ul class="stack-list" aria-label="Теги статьи">
          {post.data.tags.map((tag) => (
            <li>{tag}</li>
          ))}
        </ul>
      )}

      <div class="prose">
        <Content />
      </div>
    </article>
  </main>

  <SiteFooter noteRu={uiCopy.footer.blogNote.ru} noteEn={uiCopy.footer.blogNote.en} />

  <script is:inline type="module" src={localeScriptUrl}></script>
</Layout>
