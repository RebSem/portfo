---
import { getCollection } from 'astro:content';
import SiteFooter from '../../../components/SiteFooter.astro';
import SiteHeader from '../../../components/SiteHeader.astro';
import { heroDisplayName, uiCopy } from '../../../data/site-content';
import Layout from '../../../layouts/Layout.astro';
import localeScriptUrl from '../../../scripts/locale.js?url';

const posts = (await getCollection('blog', ({ data }) => !data.draft && data.lang === 'ru'))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const blogSchema = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  url: 'https://rebsem.ru/ru/blog',
  name: `${heroDisplayName.ru} Блог`,
  description: 'Публикации о продуктовой логике, системах delivery, разработке и практическом использовании AI.',
  inLanguage: 'ru',
};
---

<Layout 
  title={`${heroDisplayName.ru} — Блог`} 
  description="Блог о продуктовой логике, системах delivery, разработке и практическом использовании AI." 
  schema={blogSchema}
>
  <a id="skip-to-content" href="#main-content" class="skip-link">Перейти к содержимому</a>

  <SiteHeader active="blog" />

  <div class="divider-wrap" aria-hidden="true">
    <hr class="divider" />
  </div>

  <main
    id="main-content"
    class="page-main"
  >
    <section class="blog-index" aria-labelledby="blog-title">
      <div class="section-head">
        <h1 id="blog-title">Блог</h1>
        <p>Публикации о продуктовой логике, системах delivery и практическом использовании AI.</p>
      </div>

      {posts.length === 0 ? (
        <p class="blog-empty">Для этой локали пока нет опубликованных постов.</p>
      ) : (
        <ul id="blog-list" class="blog-list">
          {posts.map((post) => {
            const isoDate = post.data.publishedAt.toISOString().slice(0, 10);
            const dateLabel = new Intl.DateTimeFormat('ru-RU', {
              day: 'numeric',
              month: 'long',
              year: 'numeric',
            }).format(post.data.publishedAt);

            return (
              <li class="blog-card">
                <article>
                  <header class="blog-card-head">
                    <p class="blog-card-meta">
                      <time class="blog-date" datetime={isoDate}>{dateLabel}</time>
                      <span class="blog-lang">Русский</span>
                    </p>
                    <h3>
                      <a href={`/ru/blog/${post.slug}`}>{post.data.title}</a>
                    </h3>
                  </header>
                  <p>{post.data.description}</p>
                </article>
              </li>
            );
          })}
        </ul>
      )}
    </section>
  </main>

  <SiteFooter noteRu={uiCopy.footer.blogNote.ru} noteEn={uiCopy.footer.blogNote.en} />

  <script is:inline type="module" src={localeScriptUrl}></script>
</Layout>
