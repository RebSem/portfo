---
import { Image } from 'astro:assets';
import SiteFooter from '../../components/SiteFooter.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SocialLinks from '../../components/SocialLinks.astro';
import {
  aboutParagraphs,
  githubUsername,
  heroDisplayName,
  heroSubtitle,
  linkedinUrl,
  telegramUrl,
} from '../../data/site-content';
import Layout from '../../layouts/Layout.astro';
import githubScriptUrl from '../../scripts/github-activity.js?url';
import localeScriptUrl from '../../scripts/locale.js?url';
import heroImage from '../../assets/main-hero.jpg';

const avatarUrl = `https://avatars.githubusercontent.com/${githubUsername}?size=560`;
const aboutSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  url: 'https://rebsem.ru/ru/about',
  name: `${heroDisplayName.ru} - Обо мне`,
  inLanguage: 'ru',
  mainEntity: {
    '@type': 'Person',
    name: heroDisplayName.en,
    alternateName: heroDisplayName.ru,
    jobTitle: 'Product Manager (AI) / Product Engineer',
    image: avatarUrl,
    sameAs: [
      `https://github.com/${githubUsername}`,
      telegramUrl,
      linkedinUrl,
    ],
    description: heroSubtitle.ru,
  },
};
---

<Layout
  title={`${heroDisplayName.ru} - Обо мне`}
  description="Product Manager в Prof-IT (zvonobot, effebot, p1sms), веду голосовых AI-агентов для B2B. Как я работаю, где приношу пользу и в какие роли открыт."
  schema={aboutSchema}
>
  <a id="skip-to-content" href="#main-content" class="skip-link">Перейти к содержимому</a>

  <SiteHeader active="about" />

  <div class="divider-wrap" aria-hidden="true">
    <hr class="divider" />
  </div>

  <main
    id="main-content"
    class="page-main"
  >
    <section class="about-section" aria-labelledby="about-title">
      <p class="about-eyebrow">Обо мне</p>

      <h1 id="about-title">
        <span id="hero-name">{heroDisplayName.ru}</span>
      </h1>

      <p class="about-intro">Product Manager voice AI в Prof-IT. Как я работаю, где приношу больше всего пользы и в какие роли открыт.</p>

      <div class="about-grid">
        <div class="about-image-wrap">
          <Image
            id="hero-avatar"
            src={heroImage}
            width={560}
            height={560}
            loading="eager"
            alt={`Портрет ${heroDisplayName.ru}`}
          />
        </div>

        <div class="about-copy">
          <p id="hero-subtitle">{heroSubtitle.ru}</p>

          {
            aboutParagraphs.map((paragraph) => (
              <p>{paragraph.ru}</p>
            ))
          }

          <SocialLinks className="social-links profile-social-links" />
        </div>
      </div>
    </section>

    <section id="github" class="section-block" aria-labelledby="github-title">
      <div class="section-head">
        <h2 id="github-title">GitHub активность</h2>
        <p>GitHub-профиль и график активности за последний год.</p>
      </div>

      <div class="github-heatmap">
        <div class="heatmap-topline">
          <strong id="contributions-total">0</strong>
          <span>вкладов за последний год</span>
        </div>

        <p class="github-meta">
          <a
            id="github-profile-link"
            class="github-profile-link"
            href={`https://github.com/${githubUsername}`}
            target="_blank"
            rel="noreferrer"
          >
            github.com/{githubUsername}
          </a>
          <span class="github-snapshot-note">График вкладов обновляется во время сборки сайта.</span>
        </p>

        <div
          id="contribution-grid"
          class="contribution-grid"
          role="img"
          aria-label="График активности GitHub"
        ></div>

        <div class="heatmap-legend" aria-hidden="true">
          <span>0</span>
          <div class="legend-level level-0"></div>
          <div class="legend-level level-1"></div>
          <div class="legend-level level-2"></div>
          <div class="legend-level level-3"></div>
          <div class="legend-level level-4"></div>
          <span>max</span>
        </div>

        <p
          id="contribution-tooltip"
          class="contribution-tooltip"
          data-hint-ru="Наведите или перейдите на ячейку, чтобы увидеть дату и число вкладов."
          data-hint-en="Hover or focus a cell to see the exact date and number of contributions."
        >
          Наведите или перейдите на ячейку, чтобы увидеть дату и число вкладов.
        </p>

        <p
          id="github-error"
          class="github-error hidden"
        >
          Не удалось загрузить GitHub-данные. Попробуйте обновить страницу позже.
        </p>
      </div>
    </section>
  </main>

  <SiteFooter />

  <script is:inline type="module" src={localeScriptUrl}></script>
  <script is:inline type="module" src={githubScriptUrl}></script>
</Layout>
