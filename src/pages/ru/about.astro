---
import { Image } from 'astro:assets';
import SiteFooter from '../../components/SiteFooter.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import {
  aboutBlocks,
  buildPersonSchema,
  githubUsername,
  heroDisplayName,
  heroSubtitle,
  skillGroups,
  telegramUrl,
  uiCopy,
} from '../../data/site-content';
import Layout from '../../layouts/Layout.astro';
import githubScriptUrl from '../../scripts/github-activity.js?url';
import localeScriptUrl from '../../scripts/locale.js?url';
import heroImage from '../../assets/main-hero.jpg';

const avatarUrl = `https://avatars.githubusercontent.com/${githubUsername}?size=560`;
// Колонка с фото занята только рядом с первыми двумя блоками; дальше страница
// перетекает в одну центрированную колонку (без пустого рельса в 320px).
const gridBlocks = aboutBlocks.slice(0, 2);
const flowBlocks = aboutBlocks.slice(2);
const personEntity = buildPersonSchema('https://rebsem.ru/ru/about');
personEntity.image = avatarUrl;
const aboutSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  url: 'https://rebsem.ru/ru/about',
  name: `${heroDisplayName.ru} - Обо мне`,
  inLanguage: 'ru',
  mainEntity: personEntity,
};
---

<Layout
  title={`${heroDisplayName.ru} - Обо мне`}
  description="AI Product Manager в Prof-IT, который драйвит продукт через продуманное внедрение AI. Как я работаю, где приношу больше всего пользы, ключевые навыки и в какие роли открыт. Remote, GMT+5, открыт к релокации."
  schema={aboutSchema}
  alternate="/about"
>
  <a id="skip-to-content" href="#main-content" class="skip-link">Перейти к содержимому</a>

  <SiteHeader active="about" />

  <main
    id="main-content"
    class="page-main"
  >
    <section class="about-section" aria-labelledby="about-title">
      <p class="about-eyebrow">Обо мне</p>

      <h1 id="about-title">
        <span id="hero-name">{heroDisplayName.ru}</span>
      </h1>

      <p class="about-intro">{heroSubtitle.ru}</p>

      <div class="about-grid">
        <div class="about-image-wrap">
          <Image
            id="hero-avatar"
            src={heroImage}
            width={560}
            height={700}
            loading="eager"
            alt="Портрет Михаила Семёнова"
          />
        </div>

        <div class="about-copy">
          <div class="about-blocks">
            {gridBlocks.map((block) => (
              <article class="about-block">
                <p class="about-block-eyebrow">{block.eyebrow.ru}</p>
                <h2 class="about-block-title">{block.title.ru}</h2>
                {block.body.map((para) => (<p>{para.ru}</p>))}
                {block.bullets && (
                  <ul class="about-bullets">
                    {block.bullets.map((item) => (<li>{item.ru}</li>))}
                  </ul>
                )}
              </article>
            ))}
          </div>
        </div>
      </div>

      <div class="about-flow">
        <div class="about-blocks">
          {flowBlocks.map((block) => (
            <article class="about-block">
              <p class="about-block-eyebrow">{block.eyebrow.ru}</p>
              <h2 class="about-block-title">{block.title.ru}</h2>
              {block.body.map((para) => (<p>{para.ru}</p>))}
              {block.bullets && (
                <ul class="about-bullets">
                  {block.bullets.map((item) => (<li>{item.ru}</li>))}
                </ul>
              )}
            </article>
          ))}
        </div>

        <section class="about-skills" aria-labelledby="about-skills-title">
            <p class="about-block-eyebrow">{uiCopy.about.skillsEyebrow.ru}</p>
            <h2 id="about-skills-title" class="about-block-title">{uiCopy.about.skillsTitle.ru}</h2>
            <p class="about-skills-note">{uiCopy.about.skillsNote.ru}</p>
            <div class="skill-groups">
              {skillGroups.map((group) => (
                <div class="skill-group">
                  <p class="skill-group-label">{group.label.ru}</p>
                  <ul class="skill-chips" aria-label={group.label.ru}>
                    {group.items.map((item) => (<li class="skill-chip">{item}</li>))}
                  </ul>
                </div>
              ))}
            </div>
          </section>

        <div class="about-cta-card">
          <p class="about-cta-eyebrow">Связаться</p>
          <p class="about-cta-headline">Открыт к ролям AI Product Manager, где продукт двигается за счёт продуманного внедрения AI.</p>
          <p class="about-cta-sub">Расскажите про продукт и задачу, и я подскажу, где AI реально даёт результат, а где нет.</p>
          <div class="about-cta-row">
            <a class="cta-button cta-primary" href={telegramUrl} target="_blank" rel="noreferrer">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4 11l16 -8l-4 18l-5 -4l-3 3l1 -5l8 -7"/>
              </svg>
              {uiCopy.home.heroCtaPrimary.ru}
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />

  <script is:inline type="module" src={localeScriptUrl}></script>
  <script is:inline type="module" src={githubScriptUrl}></script>
</Layout>
