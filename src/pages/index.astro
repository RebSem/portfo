---
import { getCollection } from 'astro:content';
import AgentOps from '../components/AgentOps.astro';
import FeaturedCase from '../components/FeaturedCase.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SocialLinks from '../components/SocialLinks.astro';
import { projects } from '../data/projects';
import {
  buildPersonSchema,
  cvPath,
  email,
  githubUsername,
  heroFallbackName,
  linkedinUrl,
  locationSignal,
  telegramUrl,
  uiCopy,
} from '../data/site-content';
import Layout from '../layouts/Layout.astro';
import githubScriptUrl from '../scripts/github-activity.js?url';
import githubSyncScriptUrl from '../scripts/github-sync.js?url';
import localeScriptUrl from '../scripts/locale.js?url';
import metricSpotlightScriptUrl from '../scripts/metric-spotlight.js?url';

const visibleProjects = projects.filter((project) => !project.placeholder);
const featuredCaseProject = visibleProjects.find((p) => p.id === 'zvonobot-ai');
const workLedProjects = visibleProjects.filter((p) => p.tier === 'work-led' && p.id !== 'zvonobot-ai');
const petProjects = visibleProjects
  .filter((p) => p.tier === 'pet')
  .sort((a, b) => (a.petOrder ?? 99) - (b.petOrder ?? 99));
const projectEntries = await getCollection('projects', ({ data }) => !data.draft && data.lang === 'en');

const personSchema = buildPersonSchema('https://rebsem.ru/');
---

<Layout
  title={`${heroFallbackName} - AI Product Manager`}
  description="AI Product Manager at Prof-IT (zvonobot, effebot, p1sms) who drives the product through thoughtful AI adoption. 500,000+ minutes of B2B AI agent conversations in 2026. Ships pet projects with AI agents in days, not sprints. Remote, GMT+5, EN/RU, open to relocation."
  schema={personSchema}
  alternate="/ru/"
>
  <a id="skip-to-content" href="#main-content" class="skip-link">Skip to content</a>

  <SiteHeader active="home" />

  <main id="main-content" class="page-main" data-github-username={githubUsername}>
    <section class="home-intro" aria-labelledby="home-title">
      <div class="home-intro-copy">
        <div class="hero-status-row">
          <span class="hero-status">
            <span class="pulse-dot"></span>
            {uiCopy.home.heroStatus.en}
          </span>
          <span class="hero-location" aria-label="Location and work format">{locationSignal.en}</span>
        </div>

        <p class="about-eyebrow">{uiCopy.home.eyebrow.en}</p>

        <h1 id="home-title">
          <span class="hero-accent">AI</span> <span class="hero-serif">Product</span>&nbsp;Manager.
        </h1>

        <p class="home-lead">
          {uiCopy.home.lead.en}
          <br />
          <span class="home-lead-strong">{uiCopy.home.leadStrong.en}</span>
        </p>

        <div class="hero-cta-row">
          <a class="cta-button cta-primary" href={telegramUrl} target="_blank" rel="noreferrer">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4 11l16 -8l-4 18l-5 -4l-3 3l1 -5l8 -7"/>
            </svg>
            {uiCopy.home.heroCtaPrimary.en}
          </a>
          <a class="cta-button cta-secondary" href={`mailto:${email}`}>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z"/>
              <path d="M3 7l9 6l9 -6"/>
            </svg>
            {uiCopy.home.heroCtaEmail.en}
          </a>
          <a class="cta-button cta-secondary" href={linkedinUrl} target="_blank" rel="noreferrer">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M8 11v5"/><path d="M8 8v.01"/><path d="M12 16v-5"/><path d="M16 16v-3a2 2 0 1 0 -4 0"/>
              <path d="M3 7a4 4 0 0 1 4 -4h10a4 4 0 0 1 4 4v10a4 4 0 0 1 -4 4h-10a4 4 0 0 1 -4 -4z"/>
            </svg>
            {uiCopy.home.heroCtaLinkedin.en}
          </a>
          <a class="cta-button cta-ghost" href={cvPath} target="_blank" rel="noreferrer">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M14 3v4a1 1 0 0 0 1 1h4"/>
              <path d="M17 21h-10a2 2 0 0 1 -2 -2v-14a2 2 0 0 1 2 -2h7l5 5v11a2 2 0 0 1 -2 2z"/>
              <path d="M12 11v6"/><path d="M9.5 14.5l2.5 2.5l2.5 -2.5"/>
            </svg>
            {uiCopy.home.heroCtaCv.en}
          </a>
        </div>

        <SocialLinks className="social-links profile-social-links" />
      </div>

      <aside class="hero-metric-card" aria-label="Key metric">
        <p class="hero-metric-label">{uiCopy.home.metricLabel.en}</p>
        <p class="hero-metric-value">
          {uiCopy.home.metricNumber}<span class="unit">{uiCopy.home.metricUnit.en}</span>
        </p>
        <p class="hero-metric-caption">{uiCopy.home.metricCaption.en}</p>
        <p class="hero-metric-footnote">
          <span>{uiCopy.home.metricFootnoteOne.en}</span>
          <span>{uiCopy.home.metricFootnoteTwo.en}</span>
        </p>
      </aside>
    </section>

    <section class="section-block currently-section" aria-labelledby="currently-title">
      <div class="section-head">
        <p class="about-eyebrow">{uiCopy.home.currentlyEyebrow.en}</p>
        <h2 id="currently-title">{uiCopy.home.currentlyTitle.en}</h2>
      </div>

      <dl class="currently-grid">
        <div class="currently-item">
          <dt>{uiCopy.home.currentlyRoleLabel.en}</dt>
          <dd>{uiCopy.home.currentlyRole.en}</dd>
        </div>
        <div class="currently-item">
          <dt>{uiCopy.home.currentlyFocusLabel.en}</dt>
          <dd>{uiCopy.home.currentlyFocus.en}</dd>
        </div>
        <div class="currently-item currently-item-metric">
          <dt>{uiCopy.home.currentlyMetricLabel.en}</dt>
          <dd>{uiCopy.home.currentlyMetricValue.en}</dd>
        </div>
      </dl>

      <div class="github-inline" aria-labelledby="github-title">
        <div class="github-inline-meta">
          <span class="label">GitHub · last year</span>
          <strong id="contributions-total">0</strong>
          <span class="label" id="github-title">contributions</span>
          <a
            class="github-profile-link link"
            href={`https://github.com/${githubUsername}`}
            target="_blank"
            rel="noreferrer"
          >
            github.com/{githubUsername}
          </a>
        </div>

        <div class="github-heatmap">
          <div
            id="contribution-grid"
            class="contribution-grid"
            role="group"
            aria-label="GitHub activity graph"
          ></div>

          <div class="heatmap-legend" aria-hidden="true">
            <span>0</span>
            <div class="legend-level level-0"></div>
            <div class="legend-level level-1"></div>
            <div class="legend-level level-2"></div>
            <div class="legend-level level-3"></div>
            <div class="legend-level level-4"></div>
            <span>max</span>
          </div>

          <p
            id="contribution-tooltip"
            class="contribution-tooltip"
            data-hint-ru="Наведите на ячейку, чтобы увидеть дату и число вкладов."
            data-hint-en="Hover a cell to see the exact date and number of contributions."
          >
            Hover a cell to see the exact date and number of contributions.
          </p>

          <p
            id="github-error"
            class="github-error hidden"
          >
            Unable to load GitHub data. Please refresh later.
          </p>
        </div>
      </div>
    </section>

    <AgentOps locale="en" />

    <section id="projects" class="section-block" aria-labelledby="projects-title">
      <div class="section-head">
        <p class="about-eyebrow">{uiCopy.projects.title.en}</p>
        <h2 id="projects-title">Selected work</h2>
        <p>{uiCopy.projects.subtitle.en}</p>
      </div>

      <div class="projects-tier">
        <div class="projects-tier-head">
          <span class="tier-eyebrow">{uiCopy.projects.workLedEyebrow.en}</span>
          <h3>{uiCopy.projects.workLedTitle.en}</h3>
          <p>{uiCopy.projects.workLedNote.en}</p>
        </div>

        {featuredCaseProject && (() => {
          const fEntry = projectEntries.find((e) => e.data.projectId === featuredCaseProject.id);
          return (
            <FeaturedCase
              project={featuredCaseProject}
              locale="en"
              screenshotLight="/projects/zvonobot-dashboard-en-light.png"
              screenshotDark="/projects/zvonobot-dashboard-en-dark.png"
              caseHref={fEntry ? `/projects/${fEntry.slug}/` : undefined}
            />
          );
        })()}

        <div class="projects-led-grid">
          {workLedProjects.map((project) => {
            const entry = projectEntries.find(e => e.data.projectId === project.id);
            return (
              <article
                class:list={["project-card", project.id === 'cursivo' && "project-card-featured"]}
                data-github-repo={project.githubRepo}
              >
                <div class="project-card-head">
                  {entry ? (
                    <h3><a href={`/projects/${entry.slug}/`}>{project.title.en}</a></h3>
                  ) : (
                    <h3>{project.title.en}</h3>
                  )}
                  {project.id === 'cursivo' && (
                    <div class="launch-badge">
                      <span class="pulse-dot"></span>
                      Live
                    </div>
                  )}
                  {project.id === 'obrabot' && (
                    <span class="project-visibility">Internal Prof-IT product</span>
                  )}
                </div>

                <p>{project.summary.en}</p>
                <p class="project-meta">
                  <strong>Type</strong>
                  <span>{project.appType.en}</span>
                </p>
                {project.githubRepo && (
                  <div class="project-live-facts" aria-label="Live GitHub repository details">
                    <p class="project-fact-chip">
                      <span>Language</span>
                      <strong data-github-language>{project.stack[0]}</strong>
                    </p>
                    <p class="project-fact-chip">
                      <span>Stars</span>
                      <strong data-github-stars>0</strong>
                    </p>
                    <p class="project-fact-chip">
                      <span>Last push</span>
                      <strong data-github-updated>Syncing…</strong>
                    </p>
                  </div>
                )}
                <ul class="stack-list" aria-label="Project technologies">
                  {project.stack.map((item) => (<li>{item}</li>))}
                </ul>
                <p class="project-links">
                  {entry && (
                    <a
                      class="project-link"
                      href={`/projects/${entry.slug}`}
                      data-details-link
                    >
                      Read case
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
                    </a>
                  )}
                  {project.demoUrl && project.id === 'cursivo' && (
                    <a class="project-link project-link-primary" href={project.demoUrl} target="_blank" rel="noreferrer">
                      Open cursivo.xyz
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7M9 7h8v8"/></svg>
                    </a>
                  )}
                  {project.demoUrl && project.id !== 'cursivo' && (
                    <a class="project-link" href={project.demoUrl} target="_blank" rel="noreferrer">
                      Live
                    </a>
                  )}
                  {project.repoUrl && (
                    <a
                      class="project-link"
                      href={project.repoUrl}
                      target="_blank"
                      rel="noreferrer"
                      data-github-repo-link={project.githubRepo ? '' : undefined}
                    >
                      Repo
                    </a>
                  )}
                </p>
              </article>
            );
          })}
        </div>
      </div>

      <div class="projects-tier">
        <div class="projects-tier-head">
          <span class="tier-eyebrow">{uiCopy.projects.petEyebrow.en}</span>
          <h3>{uiCopy.projects.petTitle.en}</h3>
          <p>{uiCopy.projects.petNote.en}</p>
        </div>

        <div class="projects-pet-grid">
          {petProjects.map((project) => {
            const entry = projectEntries.find(e => e.data.projectId === project.id);
            return (
              <article
                class="project-card-pet"
                data-github-repo={project.githubRepo}
              >
                {project.shipTime && (
                  <span class="pet-ship-time">
                    <span class="pulse-dot"></span>
                    {project.shipTime.en}
                  </span>
                )}
                {entry ? (
                  <h4><a href={`/projects/${entry.slug}/`}>{project.title.en}</a></h4>
                ) : (
                  <h4>{project.title.en}</h4>
                )}
                <p class="pet-type">{project.appType.en}</p>
                {project.proof && (
                  <p class="pet-proof">
                    <span class="pet-proof-label">Proves</span>
                    {project.proof.en}
                  </p>
                )}
                <p class="pet-stack">{project.stack.join(' · ')}</p>
                {project.repoUrl && (
                  <a class="pet-repo-link" href={project.repoUrl} target="_blank" rel="noreferrer">
                    github →
                  </a>
                )}
              </article>
            );
          })}
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />

  <script is:inline type="module" src={localeScriptUrl}></script>
  <script is:inline type="module" src={githubScriptUrl}></script>
  <script is:inline type="module" src={githubSyncScriptUrl}></script>
  <script is:inline type="module" src={metricSpotlightScriptUrl}></script>
</Layout>
