---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SocialLinks from '../components/SocialLinks.astro';
import { projects } from '../data/projects';
import { githubUsername, heroDisplayName, heroFallbackName, linkedinUrl, telegramUrl, uiCopy } from '../data/site-content';
import Layout from '../layouts/Layout.astro';
import githubScriptUrl from '../scripts/github-activity.js?url';
import githubSyncScriptUrl from '../scripts/github-sync.js?url';
import localeScriptUrl from '../scripts/locale.js?url';
import heroImage from '../assets/main-hero.jpg';

const visibleProjects = projects.filter((project) => !project.placeholder);
const projectEntries = await getCollection('projects', ({ data }) => !data.draft && data.lang === 'en');

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: heroDisplayName.en,
  alternateName: heroDisplayName.ru,
  jobTitle: 'Product Manager (AI) / Product Engineer',
  url: 'https://rebsem.ru/',
  image: 'https://rebsem.ru/main-hero.jpg',
  sameAs: [
    `https://github.com/${githubUsername}`,
    telegramUrl,
    linkedinUrl,
  ],
};
---

<Layout
  title={`${heroFallbackName} - Portfolio`}
  description="Product Manager at Prof-IT (zvonobot, effebot, p1sms). Leading voice AI agents for B2B — 500K+ conversation minutes in 2026. Codes pet projects to validate hypotheses fast."
  schema={personSchema}
>
  <a id="skip-to-content" href="#main-content" class="skip-link">Skip to content</a>

  <SiteHeader active="home" />

  <div class="divider-wrap" aria-hidden="true">
    <hr class="divider" />
  </div>

  <main id="main-content" class="page-main" data-github-username={githubUsername}>
    <section class="home-intro" aria-labelledby="home-title">
      <div class="home-intro-copy">
        <p class="about-eyebrow">{uiCopy.home.eyebrow.en}</p>

        <h1 id="home-title">{uiCopy.home.title.en}</h1>

        <p class="home-lead">{uiCopy.home.lead.en}</p>

        <SocialLinks className="social-links profile-social-links" />
      </div>

      <div class="home-avatar-wrap">
        <Image
          class="home-avatar"
          src={heroImage}
          width={320}
          height={320}
          loading="eager"
          alt="Photo of Mikhail Semenov"
        />
      </div>
    </section>

    <section class="section-block currently-section" aria-labelledby="currently-title">
      <div class="section-head">
        <p class="about-eyebrow">{uiCopy.home.currentlyEyebrow.en}</p>
        <h2 id="currently-title">{uiCopy.home.currentlyTitle.en}</h2>
      </div>

      <dl class="currently-grid">
        <div class="currently-item">
          <dt>{uiCopy.home.currentlyRoleLabel.en}</dt>
          <dd>{uiCopy.home.currentlyRole.en}</dd>
        </div>
        <div class="currently-item">
          <dt>{uiCopy.home.currentlyFocusLabel.en}</dt>
          <dd>{uiCopy.home.currentlyFocus.en}</dd>
        </div>
        <div class="currently-item currently-item-metric">
          <dt>{uiCopy.home.currentlyMetricLabel.en}</dt>
          <dd>{uiCopy.home.currentlyMetricValue.en}</dd>
        </div>
      </dl>
    </section>

    <section class="section-block github-activity-section" aria-labelledby="github-title">
      <div class="section-head github-activity-head">
        <div>
          <p class="about-eyebrow">GitHub</p>
          <h2 id="github-title">GitHub activity</h2>
        </div>
        <p>Public work trail from the last year.</p>
      </div>

      <div class="github-activity-card">
        <div class="github-heatmap">
          <div class="heatmap-topline">
            <strong id="contributions-total">0</strong>
            <span>contributions in the last year</span>
          </div>

          <div
            id="contribution-grid"
            class="contribution-grid"
            role="img"
            aria-label="GitHub activity graph"
          ></div>

          <div class="heatmap-legend" aria-hidden="true">
            <span>0</span>
            <div class="legend-level level-0"></div>
            <div class="legend-level level-1"></div>
            <div class="legend-level level-2"></div>
            <div class="legend-level level-3"></div>
            <div class="legend-level level-4"></div>
            <span>max</span>
          </div>

          <p
            id="contribution-tooltip"
            class="contribution-tooltip"
            data-hint-ru="Наведите или перейдите на ячейку, чтобы увидеть дату и число вкладов."
            data-hint-en="Hover or focus a cell to see the exact date and number of contributions."
          >
            Hover or focus a cell to see the exact date and number of contributions.
          </p>

          <p
            id="github-error"
            class="github-error hidden"
          >
            Unable to load GitHub data. Please refresh later.
          </p>
        </div>

        <div class="github-activity-copy">
          <p>I keep a public trail of shipped work, experiments, and site iterations on GitHub.</p>
          <p>
            <a
              class="github-profile-link"
              href={`https://github.com/${githubUsername}`}
              target="_blank"
              rel="noreferrer"
            >
              Follow me on GitHub
            </a>
            {' '}and inspect the repos behind these case studies.
          </p>
        </div>
      </div>
    </section>

    <section id="projects" class="section-block" aria-labelledby="projects-title">
      <div class="section-head">
        <h2 id="projects-title">Projects</h2>
        <p>Selected work in one consistent format: product, stack, and where it already runs. The first two are products I lead — Cursivo and the internal Prof-IT cabinet. The rest are personal pet projects shipped in 1–7 days each. Most repos are private; the only open one is this site.</p>
      </div>

      {visibleProjects.length === 0 ? (
        <p class="projects-empty">I am preparing fresh case studies. Detailed write-ups will appear here soon.</p>
      ) : (
        <div class="projects-list">
          {visibleProjects.map((project) => {
            const entry = projectEntries.find(e => e.data.projectId === project.id);
            return (
              <article
                class:list={["project-card", project.id === 'cursivo' && "project-card-featured"]}
                data-github-repo={project.githubRepo}
              >
                <div class="project-card-head">
                  {entry ? (
                    <h3><a href={`/projects/${entry.slug}/`}>{project.title.en}</a></h3>
                  ) : (
                    <h3>{project.title.en}</h3>
                  )}
                  {project.id === 'cursivo' && (
                    <div class="launch-badge">
                      <span class="pulse-dot"></span>
                      Live
                    </div>
                  )}
                  {project.id === 'obrabot' && (
                    <span class="project-visibility">Internal Prof-IT product</span>
                  )}
                  {project.visibility === 'private' && project.id !== 'cursivo' && project.id !== 'obrabot' && (
                    <span class="project-visibility">Private case</span>
                  )}
                </div>

                <p>{project.summary.en}</p>
                <p class="project-meta">
                  <strong>Type</strong>
                  <span>{project.appType.en}</span>
                </p>
                {project.githubRepo && (
                  <div class="project-live-facts" aria-label="Live GitHub repository details">
                    <p class="project-fact-chip">
                      <span>Language</span>
                      <strong data-github-language>{project.stack[0]}</strong>
                    </p>
                    <p class="project-fact-chip">
                      <span>Stars</span>
                      <strong data-github-stars>0</strong>
                    </p>
                    <p class="project-fact-chip">
                      <span>Last push</span>
                      <strong data-github-updated>Syncing…</strong>
                    </p>
                  </div>
                )}
                <ul class="stack-list" aria-label="Project technologies">
                  {project.stack.map((item) => (<li>{item}</li>))}
                </ul>
                <p class="project-links">
                  {entry && (
                    <a 
                      class="project-link" 
                      href={`/projects/${entry.slug}`}
                      data-details-link
                    >
                      Read more
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
                    </a>
                  )}
                  {project.repoUrl && (
                    <a
                      class="project-link"
                      href={project.repoUrl}
                      target="_blank"
                      rel="noreferrer"
                      data-github-repo-link={project.githubRepo ? '' : undefined}
                    >
                      Repository
                    </a>
                  )}
                </p>
              </article>
            );
          })}
        </div>
      )}
    </section>
  </main>

  <SiteFooter />

  <script is:inline type="module" src={localeScriptUrl}></script>
  <script is:inline type="module" src={githubScriptUrl}></script>
  <script is:inline type="module" src={githubSyncScriptUrl}></script>
</Layout>
