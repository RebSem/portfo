---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SocialLinks from '../components/SocialLinks.astro';
import { projects } from '../data/projects';
import { githubUsername, heroDisplayName, heroFallbackName, linkedinUrl, telegramUrl, uiCopy } from '../data/site-content';
import Layout from '../layouts/Layout.astro';
import blogScriptUrl from '../scripts/blog.js?url';
import githubSyncScriptUrl from '../scripts/github-sync.js?url';
import localeScriptUrl from '../scripts/locale.js?url';
import heroImage from '../assets/main-hero.jpg';

const visibleProjects = projects.filter((project) => !project.placeholder);
const projectEntries = await getCollection('projects', ({ data }) => !data.draft && data.lang === 'en');

const posts = (await getCollection('blog', ({ data }) => !data.draft && data.lang === 'en'))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 6);

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: heroDisplayName.en,
  alternateName: heroDisplayName.ru,
  jobTitle: 'Product Manager (AI) / Product Engineer',
  url: 'https://rebsem.ru/',
  image: 'https://rebsem.ru/main-hero.jpg',
  sameAs: [
    `https://github.com/${githubUsername}`,
    telegramUrl,
    linkedinUrl,
  ],
};
---

<Layout
  title={`${heroFallbackName} - Portfolio`}
  description="Product manager with engineering depth. I turn ambiguous product work into shipped digital products, clear interfaces, and practical AI workflows."
  schema={personSchema}
>
  <a id="skip-to-content" href="#main-content" class="skip-link">Skip to content</a>

  <SiteHeader active="home" />

  <div class="divider-wrap" aria-hidden="true">
    <hr class="divider" />
  </div>

  <main id="main-content" class="page-main" data-github-username={githubUsername}>
    <section class="home-intro" aria-labelledby="home-title">
      <div class="home-intro-copy">
        <p class="about-eyebrow">Product Manager / Product Engineer</p>

        <h1 id="home-title">{uiCopy.home.title.en}</h1>

        <p class="home-lead">{uiCopy.home.lead.en}</p>

        <SocialLinks className="social-links profile-social-links" />
      </div>

      <div class="home-avatar-wrap">
        <Image
          class="home-avatar"
          src={heroImage}
          width={320}
          height={320}
          loading="eager"
          alt="Photo of Mikhail Semenov"
        />
      </div>
    </section>

    <section class="section-block github-status-section" aria-labelledby="github-status-title">
      <div class="section-head github-status-head">
        <div>
          <p class="about-eyebrow">GitHub</p>
          <h2 id="github-status-title">{uiCopy.home.githubStatusTitle.en}</h2>
        </div>
        <p>{uiCopy.home.githubStatusSubtitle.en}</p>
      </div>

      <div class="github-status-card">
        <p
          class="github-sync-state"
          data-github-sync-status
          data-loading-ru={uiCopy.home.githubStatusLoading.ru}
          data-loading-en={uiCopy.home.githubStatusLoading.en}
          data-ready-ru={uiCopy.home.githubStatusReady.ru}
          data-ready-en={uiCopy.home.githubStatusReady.en}
          data-error-ru={uiCopy.home.githubStatusError.ru}
          data-error-en={uiCopy.home.githubStatusError.en}
        >
          {uiCopy.home.githubStatusLoading.en}
        </p>

        <div class="github-status-grid" aria-label="GitHub profile summary">
          <p class="github-status-metric">
            <span>{uiCopy.home.githubStatusRepos.en}</span>
            <strong data-github-profile="publicRepos">0</strong>
          </p>
          <p class="github-status-metric">
            <span>{uiCopy.home.githubStatusFollowers.en}</span>
            <strong data-github-profile="followers">0</strong>
          </p>
          <p class="github-status-metric">
            <span>{uiCopy.home.githubStatusFollowing.en}</span>
            <strong data-github-profile="following">0</strong>
          </p>
          <p class="github-status-metric">
            <span>{uiCopy.home.githubStatusUpdated.en}</span>
            <strong data-github-profile="updatedAt">n/a</strong>
          </p>
        </div>

        <p class="github-status-profile">
          <span>{uiCopy.home.githubStatusProfile.en}: </span>
          <a
            href={`https://github.com/${githubUsername}`}
            target="_blank"
            rel="noreferrer"
            data-github-profile-link
          >
            github.com/{githubUsername}
          </a>
        </p>
      </div>
    </section>

    <section class="section-block" aria-labelledby="recent-title">
      <div class="section-head">
        <h2 id="recent-title">Recent posts</h2>
        <p>Notes on product thinking, delivery systems, and practical AI usage.</p>
      </div>

      {posts.length === 0 ? (
        <p id="blog-empty" class="blog-empty">No published posts for this locale yet.</p>
      ) : (
        <ul id="blog-list" class="blog-list home-blog-list">
          {posts.map((post) => {
            const isoDate = post.data.publishedAt.toISOString().slice(0, 10);
            const dateLabel = new Intl.DateTimeFormat('en-US', {
              day: 'numeric',
              month: 'long',
              year: 'numeric',
            }).format(post.data.publishedAt);

            return (
              <li class="blog-card">
                <article>
                  <header class="blog-card-head">
                    <p class="blog-card-meta">
                      <time class="blog-date" datetime={isoDate}>{dateLabel}</time>
                      <span class="blog-lang">English</span>
                    </p>
                    <h3>
                      <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
                    </h3>
                  </header>
                  <p>{post.data.description}</p>
                </article>
              </li>
            );
          })}
        </ul>
      )}
    </section>

    <section id="projects" class="section-block" aria-labelledby="projects-title">
      <div class="section-head">
        <h2 id="projects-title">Projects</h2>
        <p>Five selected GitHub projects in one consistent format: product, stack, and where it already works.</p>
      </div>

      {visibleProjects.length === 0 ? (
        <p class="projects-empty">I am preparing fresh case studies. Detailed write-ups will appear here soon.</p>
      ) : (
        <div class="projects-list">
          {visibleProjects.map((project) => {
            const entry = projectEntries.find(e => e.data.projectId === project.id);
            return (
              <article
                class:list={["project-card", project.id === 'cursivo' && "project-card-featured"]}
                data-github-repo={project.githubRepo}
              >
                <div class="project-card-head">
                  {entry ? (
                    <h3><a href={`/projects/${entry.slug}/`}>{project.title.en}</a></h3>
                  ) : (
                    <h3>{project.title.en}</h3>
                  )}
                  {project.id === 'cursivo' && (
                    <div class="launch-badge">
                      <span class="pulse-dot"></span>
                      Launching Soon
                    </div>
                  )}
                  {project.visibility === 'private' && project.id !== 'cursivo' && (
                    <span class="project-visibility">Private case</span>
                  )}
                </div>

                <p>{project.summary.en}</p>
                <p class="project-meta">
                  <strong>Type</strong>
                  <span>{project.appType.en}</span>
                </p>
                {project.githubRepo && (
                  <div class="project-live-facts" aria-label="Live GitHub repository details">
                    <p class="project-fact-chip">
                      <span>Language</span>
                      <strong data-github-language>{project.stack[0]}</strong>
                    </p>
                    <p class="project-fact-chip">
                      <span>Stars</span>
                      <strong data-github-stars>0</strong>
                    </p>
                    <p class="project-fact-chip">
                      <span>Last push</span>
                      <strong data-github-updated>Syncing…</strong>
                    </p>
                  </div>
                )}
                <ul class="stack-list" aria-label="Project technologies">
                  {project.stack.map((item) => (<li>{item}</li>))}
                </ul>
                <p class="project-links">
                  {entry && (
                    <a 
                      class="project-link" 
                      href={`/projects/${entry.slug}`}
                      data-details-link
                    >
                      Read more
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
                    </a>
                  )}
                  {project.repoUrl && (
                    <a
                      class="project-link"
                      href={project.repoUrl}
                      target="_blank"
                      rel="noreferrer"
                      data-github-repo-link={project.githubRepo ? '' : undefined}
                    >
                      Repository
                    </a>
                  )}
                </p>
              </article>
            );
          })}
        </div>
      )}
    </section>
  </main>

  <SiteFooter />

  <script is:inline type="module" src={localeScriptUrl}></script>
  <script is:inline type="module" src={blogScriptUrl}></script>
  <script is:inline type="module" src={githubSyncScriptUrl}></script>
</Layout>
