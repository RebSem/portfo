---
import { Image } from 'astro:assets';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SocialLinks from '../components/SocialLinks.astro';
import {
  aboutBlocks,
  cvUrl,
  githubUsername,
  heroDisplayName,
  heroFallbackName,
  heroSubtitle,
  linkedinUrl,
  telegramUrl,
  uiCopy,
} from '../data/site-content';
import Layout from '../layouts/Layout.astro';
import githubScriptUrl from '../scripts/github-activity.js?url';
import localeScriptUrl from '../scripts/locale.js?url';
import heroImage from '../assets/main-hero.jpg';

const avatarUrl = `https://avatars.githubusercontent.com/${githubUsername}?size=560`;
const aboutSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  url: 'https://rebsem.ru/about',
  name: `${heroFallbackName} - About`,
  inLanguage: 'en',
  mainEntity: {
    '@type': 'Person',
    name: heroDisplayName.en,
    alternateName: heroDisplayName.ru,
    jobTitle: 'Product Manager (AI) / Product Engineer',
    image: avatarUrl,
    sameAs: [
      `https://github.com/${githubUsername}`,
      telegramUrl,
      linkedinUrl,
    ],
    description: heroSubtitle.en,
  },
};
---

<Layout
  title={`${heroFallbackName} - About`}
  description="Voice AI Product Manager at Prof-IT. How I work, where I add the most value, and what kind of role I am open to."
  schema={aboutSchema}
>
  <a id="skip-to-content" href="#main-content" class="skip-link">Skip to content</a>

  <SiteHeader active="about" />

  <main
    id="main-content"
    class="page-main"
  >
    <section class="about-section" aria-labelledby="about-title">
      <p class="about-eyebrow">About</p>

      <h1 id="about-title">
        <span id="hero-name">{heroDisplayName.en}</span>
      </h1>

      <p class="about-intro">{heroSubtitle.en}</p>

      <div class="about-grid">
        <div class="about-image-wrap">
          <Image
            id="hero-avatar"
            src={heroImage}
            width={560}
            height={700}
            loading="eager"
            alt={`Portrait of ${heroDisplayName.en}`}
          />
        </div>

        <div class="about-copy">
          <div class="about-blocks">
            {aboutBlocks.map((block) => (
              <article class="about-block">
                <p class="about-block-eyebrow">{block.eyebrow.en}</p>
                <h2 class="about-block-title">{block.title.en}</h2>
                {block.body.map((para) => (<p>{para.en}</p>))}
                {block.bullets && (
                  <ul class="about-bullets">
                    {block.bullets.map((item) => (<li>{item.en}</li>))}
                  </ul>
                )}
              </article>
            ))}
          </div>

          <div class="about-cta-card">
            <p class="about-cta-eyebrow">Get in touch</p>
            <p class="about-cta-headline">Currently open to voice AI / B2B product roles.</p>
            <div class="hero-cta-row">
              <a class="cta-button cta-primary" href={telegramUrl} target="_blank" rel="noreferrer">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M4 11l16 -8l-4 18l-5 -4l-3 3l1 -5l8 -7"/>
                </svg>
                {uiCopy.home.heroCtaPrimary.en}
              </a>
              <a class="cta-button cta-secondary" href={cvUrl} target="_blank" rel="noreferrer" download>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M14 3v4a1 1 0 0 0 1 1h4"/>
                  <path d="M17 21h-10a2 2 0 0 1 -2 -2v-14a2 2 0 0 1 2 -2h7l5 5v11a2 2 0 0 1 -2 2z"/>
                  <path d="M12 11v6"/>
                  <path d="M9.5 14.5l2.5 2.5l2.5 -2.5"/>
                </svg>
                {uiCopy.home.heroCtaSecondary.en}
              </a>
            </div>
            <SocialLinks className="social-links profile-social-links" />
          </div>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />

  <script is:inline type="module" src={localeScriptUrl}></script>
  <script is:inline type="module" src={githubScriptUrl}></script>
</Layout>
