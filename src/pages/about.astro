---
import { Image } from 'astro:assets';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SocialLinks from '../components/SocialLinks.astro';
import {
  aboutParagraphs,
  githubUsername,
  heroDisplayName,
  heroFallbackName,
  heroStatusError,
  heroStatusLoading,
  heroStatusReady,
  heroSubtitle,
  linkedinUrl,
  telegramUrl,
} from '../data/site-content';
import Layout from '../layouts/Layout.astro';
import githubScriptUrl from '../scripts/github-activity.js?url';
import githubSyncScriptUrl from '../scripts/github-sync.js?url';
import localeScriptUrl from '../scripts/locale.js?url';
import heroImage from '../assets/main-hero.jpg';

const avatarUrl = `https://avatars.githubusercontent.com/${githubUsername}?size=560`;
const aboutSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  url: 'https://rebsem.ru/about',
  name: `${heroFallbackName} - About`,
  inLanguage: 'en',
  mainEntity: {
    '@type': 'Person',
    name: heroDisplayName.en,
    alternateName: heroDisplayName.ru,
    jobTitle: 'Product Manager (AI) / Product Engineer',
    image: avatarUrl,
    sameAs: [
      `https://github.com/${githubUsername}`,
      telegramUrl,
      linkedinUrl,
    ],
    description: heroSubtitle.en,
  },
};
---

<Layout
  title={`${heroFallbackName} - About`}
  description="About page covering product work, delivery approach, AI focus, and a public GitHub trail."
  schema={aboutSchema}
>
  <a id="skip-to-content" href="#main-content" class="skip-link">Skip to content</a>

  <SiteHeader active="about" />

  <div class="divider-wrap" aria-hidden="true">
    <hr class="divider" />
  </div>

  <main
    id="main-content"
    class="page-main"
    data-github-username={githubUsername}
  >
    <section class="about-section" aria-labelledby="about-title">
      <p class="about-eyebrow">About me</p>

      <h1 id="about-title">
        <span id="hero-name">{heroDisplayName.en}</span>
      </h1>

      <p class="about-intro">How I work across product, delivery, AI, and engineering.</p>

      <div class="about-grid">
        <div class="about-image-wrap">
          <Image
            id="hero-avatar"
            src={heroImage}
            width={560}
            height={560}
            loading="eager"
            alt={`Portrait of ${heroDisplayName.en}`}
          />
        </div>

        <div class="about-copy">
          <p id="hero-subtitle">{heroSubtitle.en}</p>

          {
            aboutParagraphs.map((paragraph) => (
              <p>{paragraph.en}</p>
            ))
          }

          <SocialLinks className="social-links profile-social-links" />

          <div class="github-stats" aria-label="GitHub profile stats">
            <p class="github-stat">
              <strong data-github-profile="publicRepos">0</strong>
              <span>Public repos</span>
            </p>
            <p class="github-stat">
              <strong data-github-profile="followers">0</strong>
              <span>Followers</span>
            </p>
            <p class="github-stat">
              <strong data-github-profile="following">0</strong>
              <span>Following</span>
            </p>
            <p class="github-stat">
              <strong data-github-profile="updatedAt">n/a</strong>
              <span>GitHub updated</span>
            </p>
          </div>

          <p
            id="hero-status"
            class="hero-status"
            data-loading-ru={heroStatusLoading.ru}
            data-loading-en={heroStatusLoading.en}
            data-ready-ru={heroStatusReady.ru}
            data-ready-en={heroStatusReady.en}
            data-error-ru={heroStatusError.ru}
            data-error-en={heroStatusError.en}
          >
            {heroStatusLoading.en}
          </p>
        </div>
      </div>
    </section>

    <section id="github" class="section-block" aria-labelledby="github-title">
      <div class="section-head">
        <h2 id="github-title">GitHub activity</h2>
        <p>GitHub profile snapshot and activity graph from the last year.</p>
      </div>

      <div class="github-heatmap">
        <div class="heatmap-topline">
          <strong id="contributions-total">0</strong>
          <span>contributions in the last year</span>
        </div>

        <p class="github-meta">
          <a
            id="github-profile-link"
            class="github-profile-link"
            href={`https://github.com/${githubUsername}`}
            target="_blank"
            rel="noreferrer"
          >
            github.com/{githubUsername}
          </a>
          <span class="github-snapshot-note">Profile stats and public repo metadata are live from GitHub. The contribution graph is refreshed during site builds.</span>
        </p>

        <div
          id="contribution-grid"
          class="contribution-grid"
          role="img"
          aria-label="GitHub activity graph"
        ></div>

        <div class="heatmap-legend" aria-hidden="true">
          <span>0</span>
          <div class="legend-level level-0"></div>
          <div class="legend-level level-1"></div>
          <div class="legend-level level-2"></div>
          <div class="legend-level level-3"></div>
          <div class="legend-level level-4"></div>
          <span>max</span>
        </div>

        <p
          id="contribution-tooltip"
          class="contribution-tooltip"
          data-hint-ru="Наведите или перейдите на ячейку, чтобы увидеть дату и число вкладов."
          data-hint-en="Hover or focus a cell to see the exact date and number of contributions."
        >
          Hover or focus a cell to see the exact date and number of contributions.
        </p>

        <p
          id="github-error"
          class="github-error hidden"
        >
          Unable to load GitHub data. Please refresh later.
        </p>
      </div>
    </section>
  </main>

  <SiteFooter />

  <script is:inline type="module" src={localeScriptUrl}></script>
  <script is:inline type="module" src={githubSyncScriptUrl}></script>
  <script is:inline type="module" src={githubScriptUrl}></script>
</Layout>
