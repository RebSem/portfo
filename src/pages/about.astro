---
import { Image } from 'astro:assets';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import {
  aboutBlocks,
  buildPersonSchema,
  githubUsername,
  heroDisplayName,
  heroFallbackName,
  heroSubtitle,
  skillGroups,
  telegramUrl,
  uiCopy,
} from '../data/site-content';
import Layout from '../layouts/Layout.astro';
import githubScriptUrl from '../scripts/github-activity.js?url';
import localeScriptUrl from '../scripts/locale.js?url';
import heroImage from '../assets/main-hero.jpg';

const avatarUrl = `https://avatars.githubusercontent.com/${githubUsername}?size=560`;
// The photo column only has content beside the first two blocks; the rest of
// the page reflows to a single centered measure (no empty 320px rail).
const gridBlocks = aboutBlocks.slice(0, 2);
const flowBlocks = aboutBlocks.slice(2);
const personEntity = buildPersonSchema('https://rebsem.ru/about');
personEntity.image = avatarUrl;
const aboutSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  url: 'https://rebsem.ru/about',
  name: `${heroFallbackName} - About`,
  inLanguage: 'en',
  mainEntity: personEntity,
};
---

<Layout
  title={`${heroFallbackName} - About`}
  description="AI Product Manager at Prof-IT who drives the product through thoughtful AI adoption. How I work, where I add the most value, my core skills, and what kind of role I am open to. Remote, GMT+5, open to relocation."
  schema={aboutSchema}
  alternate="/ru/about"
>
  <a id="skip-to-content" href="#main-content" class="skip-link">Skip to content</a>

  <SiteHeader active="about" />

  <main
    id="main-content"
    class="page-main"
  >
    <section class="about-section" aria-labelledby="about-title">
      <p class="about-eyebrow">About</p>

      <h1 id="about-title">
        <span id="hero-name">{heroDisplayName.en}</span>
      </h1>

      <p class="about-intro">{heroSubtitle.en}</p>

      <div class="about-grid">
        <div class="about-image-wrap">
          <Image
            id="hero-avatar"
            src={heroImage}
            width={560}
            height={700}
            loading="eager"
            alt={`Portrait of ${heroDisplayName.en}`}
          />
        </div>

        <div class="about-copy">
          <div class="about-blocks">
            {gridBlocks.map((block) => (
              <article class="about-block">
                <p class="about-block-eyebrow">{block.eyebrow.en}</p>
                <h2 class="about-block-title">{block.title.en}</h2>
                {block.body.map((para) => (<p>{para.en}</p>))}
                {block.bullets && (
                  <ul class="about-bullets">
                    {block.bullets.map((item) => (<li>{item.en}</li>))}
                  </ul>
                )}
              </article>
            ))}
          </div>
        </div>
      </div>

      <div class="about-flow">
        <div class="about-blocks">
          {flowBlocks.map((block) => (
            <article class="about-block">
              <p class="about-block-eyebrow">{block.eyebrow.en}</p>
              <h2 class="about-block-title">{block.title.en}</h2>
              {block.body.map((para) => (<p>{para.en}</p>))}
              {block.bullets && (
                <ul class="about-bullets">
                  {block.bullets.map((item) => (<li>{item.en}</li>))}
                </ul>
              )}
            </article>
          ))}
        </div>

        <section class="about-skills" aria-labelledby="about-skills-title">
            <p class="about-block-eyebrow">{uiCopy.about.skillsEyebrow.en}</p>
            <h2 id="about-skills-title" class="about-block-title">{uiCopy.about.skillsTitle.en}</h2>
            <p class="about-skills-note">{uiCopy.about.skillsNote.en}</p>
            <div class="skill-groups">
              {skillGroups.map((group) => (
                <div class="skill-group">
                  <p class="skill-group-label">{group.label.en}</p>
                  <ul class="skill-chips" aria-label={group.label.en}>
                    {group.items.map((item) => (<li class="skill-chip">{item}</li>))}
                  </ul>
                </div>
              ))}
            </div>
          </section>

        <div class="about-cta-card">
          <p class="about-cta-eyebrow">Get in touch</p>
          <p class="about-cta-headline">Open to AI Product Manager roles where the product moves through smart AI adoption.</p>
          <p class="about-cta-sub">Tell me about the product and the problem, and I'll tell you where AI actually moves the needle and where it doesn't.</p>
          <div class="about-cta-row">
            <a class="cta-button cta-primary" href={telegramUrl} target="_blank" rel="noreferrer">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4 11l16 -8l-4 18l-5 -4l-3 3l1 -5l8 -7"/>
              </svg>
              {uiCopy.home.heroCtaPrimary.en}
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />

  <script is:inline type="module" src={localeScriptUrl}></script>
  <script is:inline type="module" src={githubScriptUrl}></script>
</Layout>
